VerticalScrollSelectList {
    width: 40;
    dock: left;
}

VerticalGroup {
    height: 100%;
}

SelectedPokemonPreview {
    height: 100%;
    width: 100%;
}

.buttons-container {
    dock: bottom;
    width: 100%;
    height:5;
    background: $panel;
    padding: 1 2;
    layout: horizontal;
    align: right middle;
}

.buttons-container Button {
    margin: 0 0 0 1;
}

